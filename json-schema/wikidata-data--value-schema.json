{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/wikidata/refs/heads/main/json-schema/wikidata-data--value-schema.json",
  "title": "DataValue",
  "description": "DataValue schema from Wikidata REST API & MediaWiki API",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "value",
        "somevalue",
        "novalue"
      ]
    },
    "content": {
      "description": "Value content \u2014 depends on property datatype",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "object"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}