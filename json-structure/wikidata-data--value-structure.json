{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/wikidata/refs/heads/main/json-structure/wikidata-data--value-structure.json",
  "description": "DataValue schema from Wikidata REST API & MediaWiki API",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "value",
        "somevalue",
        "novalue"
      ]
    },
    "content": {
      "description": "Value content \u2014 depends on property datatype",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "double"
        },
        {
          "type": "object"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "name": "DataValue"
}